{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "routes": [
    { "src": "^/$",           "dest": "/landing.html" },
    { "src": "^/app(/.*)?$",  "dest": "/index.html"   },
    { "src": "^/(.*\\..+)$",  "dest": "/$1"           }
  ],
  "env": {
    "VITE_API_URL": "@odintx_api_url"
  }
}
