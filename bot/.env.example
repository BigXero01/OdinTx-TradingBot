TELEGRAM_BOT_TOKEN=your_bot_token_here
# Set to your Vercel deployment URL after deploying frontend
TELEGRAM_WEBAPP_URL=https://your-app.vercel.app/app/dashboard
# Set to your Railway API service URL
ODINTX_API_URL=https://your-api.up.railway.app/api
# Path for subscriber SQLite DB — Railway: use /app/data/subscribers.db
SUBSCRIBERS_DB=/app/data/subscribers.db
