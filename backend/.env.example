# === Railway sets PORT automatically — do not override ===
# PORT=8000

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
# URL of your deployed Vercel Mini App (update after Vercel deploy)
TELEGRAM_WEBAPP_URL=https://your-app.vercel.app/app/dashboard
# URL of your Railway backend (used by bot service to fetch signals)
ODINTX_API_URL=https://your-api.up.railway.app/api

# ── APIs (optional — app falls back to mock data without these) ──
COINGECKO_API_KEY=your_coingecko_key_here
TON_API_KEY=your_ton_api_key_here
TON_NETWORK=mainnet

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-64-char-string

# ── CORS — add your Vercel URL here ──────────────────────
CORS_ORIGINS=["http://localhost:5173","https://your-app.vercel.app"]

# ── Bot subscriber DB (Railway volume path recommended) ───
SUBSCRIBERS_DB=subscribers.db
